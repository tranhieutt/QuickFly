# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Duffel (https://duffel.com)
DUFFEL_TOKEN=duffel_test_your-token-here

# Server
PORT=3000
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Config
API_TIMEOUT_MS=8000
VND_EXCHANGE_RATE=25000
DUFFEL_MAX_RESULTS=15
MAX_RESULTS=3
RATE_LIMIT_RPM=20
LOG_LEVEL=info
